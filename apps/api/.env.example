PORT=8080
HOST_POSTGRES_PORT=5432
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/zangaka_mori?sslmode=disable

# === 認証モード（どちらか一方を設定） ===

# ローカル開発用デバッグ認証（フロント側の KAKEIBO_DEBUG_UID と合わせて使用）
# これを true にすると X-Debug-Firebase-Uid ヘッダで認証をバイパスできる
ALLOW_INSECURE_AUTH=true
FIREBASE_PROJECT_ID=

# 本番用 Firebase 認証（ALLOW_INSECURE_AUTH=false にして FIREBASE_PROJECT_ID を設定）
# ALLOW_INSECURE_AUTH=false
# FIREBASE_PROJECT_ID=your-firebase-project-id
